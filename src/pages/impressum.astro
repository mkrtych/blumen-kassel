<style>
	:root {
		color: #1d1b18;
		background: #f8f5ef;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	body {
		margin: 0;
		background: #f8f5ef;
		color: #1d1b18;
	}

	a {
		color: inherit;
	}

	.legal-page {
		max-width: 860px;
		padding: 64px clamp(20px, 8vw, 120px) 96px;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 40px;
		color: #5f5a52;
		text-decoration: none;
	}

	.status {
		color: #7b3f00;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 24px;
		font-size: clamp(42px, 8vw, 84px);
		line-height: 0.95;
		letter-spacing: 0;
	}

	h2 {
		margin: 48px 0 12px;
		font-size: clamp(24px, 4vw, 36px);
		line-height: 1.1;
		letter-spacing: 0;
	}

	p {
		font-size: 18px;
		line-height: 1.7;
		letter-spacing: 0;
		color: #4f4a43;
	}
</style>

