---
const siteUrl = "https://blumenkassel.de";
const canonicalUrl = `${siteUrl}/`;
const pageTitle = "Sisters Studio – Blumen Kassel | Handgebundene Blumensträuße in Kassel";
const pageDescription =
	"Sisters Studio – Blumen Kassel gestaltet handgebundene Blumensträuße für besondere Momente. Persönliche Beratung, kreative Floristik und frische Blumen in Kassel.";
const ogTitle = "Sisters Studio – Blumen Kassel";
const ogDescription =
	"Handgebundene Blumensträuße für Momente, die mehr sagen sollen als Worte. Moderne Blumenwerkstatt in Kassel.";
const phoneNumber = "+491602233298";
const phoneDisplay = "+49 160 2233298";
const whatsappUrl = "https://wa.me/491602233298";
const instagramUrl = "https://www.instagram.com/blumen.kassel/";
const routeUrl = "https://www.google.com/maps/search/?api=1&query=Wilhelmsh%C3%B6her%20Allee%2069%2C%2034121%20Kassel";

const floristSchema = {
	"@context": "https://schema.org",
	"@type": "Florist",
	"@id": `${canonicalUrl}#florist`,
	name: "Sisters Studio – Blumen Kassel",
	url: canonicalUrl,
	telephone: phoneNumber,
	description: pageDescription,
	address: {
		"@type": "PostalAddress",
		streetAddress: "Wilhelmshöher Allee 69",
		postalCode: "34121",
		addressLocality: "Kassel",
		addressCountry: "DE",
	},
	openingHoursSpecification: [
		{
			"@type": "OpeningHoursSpecification",
			dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			opens: "10:00",
			closes: "18:00",
		},
	],
	areaServed: {
		"@type": "City",
		name: "Kassel",
	},
	sameAs: [instagramUrl],
};
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Sisters Studio – Blumen Kassel" />
		<meta property="og:locale" content="de_DE" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />

		<script type="application/ld+json" set:html={JSON.stringify(floristSchema)} />
	</head>

	<body>
		<header class="site-header">
			<a class="brand" href="/">Sisters Studio – Blumen Kassel</a>
			<nav aria-label="Hauptnavigation">
				<a href="#heute">Aktuelle Sträuße</a>
				<a href="#ueber-uns">Über uns</a>
				<a href="#kontakt">Kontakt</a>
				<a href={instagramUrl}>Instagram</a>
			</nav>
		</header>

		<main>
			<section class="hero">
				<p class="eyebrow">Sisters Studio – Blumen Kassel</p>
				<h1>Handgebundene Blumen für Momente, die mehr sagen sollen als Worte.</h1>
				<p class="hero-text">
					Jeder Strauß beginnt mit einer Geschichte. Wir gestalten Blumen nicht
					nach Schema, sondern nach dem Gefühl, das Sie weitergeben möchten.
				</p>
				<div class="actions">
					<a class="button" href="#heute">Aktuelle Sträuße ansehen</a>
					<a class="button button-secondary" href="#kontakt">Kontakt aufnehmen</a>
				</div>
			</section>

			<section class="section intro">
				<h2>Blumen, die sagen, was Worte manchmal nicht können.</h2>
				<p>
					Ob Geburtstag, Liebe, Dankbarkeit, Entschuldigung oder einfach ein
					schöner Moment zwischendurch — wir helfen Ihnen, den passenden Strauß
					dafür zu finden.
				</p>
			</section>

			<section id="heute" class="section">
				<p class="eyebrow">Heute verfügbar</p>
				<h2>Heute im Studio</h2>
				<p>
					Frisch gebundene Sträuße, die heute im Laden verfügbar sind. Jedes
					Stück ist handgemacht und nur einmal da.
				</p>
				<p class="note">Für aktuelle Verfügbarkeit schreiben Sie uns gerne direkt.</p>
				<a class="button" href={instagramUrl}>Auf Instagram ansehen</a>
			</section>

			<section id="ueber-uns" class="section">
				<p class="eyebrow">Über uns</p>
				<h2>Zwei Schwestern. Ein Studio. Viele Geschichten.</h2>
				<p>
					Sisters Studio – Blumen Kassel ist eine moderne Blumenwerkstatt in
					Kassel. Wir sind zwei Schwestern und gestalten Sträuße, die nicht wie
					Massenware wirken, sondern wie ein persönlicher Geschenk­moment.
				</p>
				<p>
					Wir beginnen nicht mit der Frage: „Welche Blumen möchten Sie?“<br />
					Wir beginnen mit der Frage: „Für wen ist dieser Strauß?“
				</p>
				<p>
					Denn für uns ist ein Blumenstrauß nicht nur ein Produkt. Er ist eine
					Botschaft zwischen zwei Menschen.
				</p>
			</section>

			<section class="section">
				<p class="eyebrow">Warum Sisters Studio</p>
				<h2>Warum Menschen zu uns kommen</h2>
				<p>
					Sie kommen nicht einfach, um Blumen zu kaufen.<br />
					Sie kommen, weil sie etwas sagen möchten.
				</p>
				<p>Vielleicht:</p>
				<ul class="quote-list">
					<li>„Ich liebe dich.“</li>
					<li>„Danke.“</li>
					<li>„Es tut mir leid.“</li>
					<li>„Ich denke an dich.“</li>
					<li>„Dieser Tag soll besonders sein.“</li>
				</ul>
				<p>Wir helfen dabei, diesem Gefühl eine Form zu geben.</p>
			</section>

			<section class="section promise">
				<p class="eyebrow">Unser Versprechen</p>
				<h2>Unser Versprechen</h2>
				<p>Wir möchten, dass Sie mit einem sicheren Gefühl gehen:</p>
				<p class="statement">„Genau das wollte ich sagen.“</p>
				<p>
					Ein Strauß ist für uns erst dann richtig, wenn er zum Menschen, zum
					Moment und zur Botschaft passt.
				</p>
			</section>

			<section class="section moments">
				<p class="eyebrow">Für welche Momente</p>
				<h2>Für Momente, die in Erinnerung bleiben</h2>
				<p>Wir gestalten Sträuße für:</p>
				<ul class="moment-list">
					<li>Geburtstage</li>
					<li>Liebe &amp; Romantik</li>
					<li>Dankbarkeit</li>
					<li>Entschuldigungen</li>
					<li>Hochzeiten</li>
					<li>besondere Überraschungen</li>
					<li>kleine Gesten im Alltag</li>
					<li>persönliche Anlässe, die keine Kategorie brauchen</li>
				</ul>
			</section>

			<section class="section compass">
				<p class="eyebrow">Unser Kompass</p>
				<h2>Unser Kompass</h2>
				<p>Vor jeder Entscheidung fragen wir uns:</p>
				<p class="statement">Hilft das, ein Gefühl ohne Verluste weiterzugeben?</p>
				<p>
					Wenn ja, ist es der richtige Weg.
				</p>
				<p>
					Diese Idee prägt unsere Beratung, unsere Gestaltung, unsere Verpackung
					und unseren Umgang mit Kunden.
				</p>
			</section>

			<section class="section philosophy">
				<p class="eyebrow">Wofür wir stehen</p>
				<h2>Wofür wir stehen</h2>
				<p>
					Wir glauben, dass Menschen nicht einfach Blumen kaufen.<br />
					Sie möchten etwas ausdrücken.
				</p>
				<p>
					Manchmal Liebe.<br />
					Manchmal Dankbarkeit.<br />
					Manchmal Nähe.<br />
					Manchmal etwas, wofür Worte nicht reichen.
				</p>
				<p>Unsere Aufgabe ist es, diesem Gefühl eine Form zu geben.</p>
				<p>
					Darum beginnt bei uns jeder Strauß mit dem Menschen, für den er gedacht
					ist.
				</p>
			</section>

			<section class="section">
				<p class="eyebrow">Instagram</p>
				<h2>Aktuelle Arbeiten</h2>
				<p>
					Viele unserer Sträuße entstehen nur einmal. Auf Instagram zeigen wir
					aktuelle Arbeiten, Einblicke aus dem Studio und Blumen, die gerade
					verfügbar sind.
				</p>
				<a class="button" href={instagramUrl}>Instagram öffnen</a>
			</section>

			<section id="kontakt" class="section contact">
				<p class="eyebrow">Kontakt</p>
				<h2>Erzählen Sie uns Ihre Geschichte</h2>
				<p>
					Sie möchten einen Strauß bestellen oder sich beraten lassen?<br />
					Schreiben Sie uns, rufen Sie uns an oder besuchen Sie uns direkt im
					Studio.
				</p>
				<address>
					Sisters Studio – Blumen Kassel<br />
					Wilhelmshöher Allee 69<br />
					34121 Kassel, Deutschland
				</address>
				<p>
					<a href={`tel:${phoneNumber}`}>{phoneDisplay}</a>
				</p>
				<div class="actions">
					<a class="button" href={whatsappUrl}>WhatsApp schreiben</a>
					<a class="button button-secondary" href={routeUrl}>Route öffnen</a>
				</div>
			</section>
		</main>

		<footer class="footer">
			<p>Sisters Studio – Blumen Kassel</p>
			<p>Handgebundene Blumensträuße in Kassel.</p>
			<nav aria-label="Footer Navigation">
				<a href="/">Start</a>
				<a href="#heute">Aktuelle Sträuße</a>
				<a href="#ueber-uns">Über uns</a>
				<a href="#kontakt">Kontakt</a>
				<a href={instagramUrl}>Instagram</a>
				<a href="/impressum/">Impressum</a>
				<a href="/datenschutz/">Datenschutz</a>
			</nav>
		</footer>
	</body>
</html>

<style>
	:root {
		color: #1d1b18;
		background: #f8f5ef;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	body {
		margin: 0;
		background: #f8f5ef;
		color: #1d1b18;
	}

	a {
		color: inherit;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 24px clamp(20px, 5vw, 72px);
	}

	.brand {
		font-weight: 700;
		text-decoration: none;
	}

	nav {
		display: flex;
		gap: 20px;
		font-size: 14px;
	}

	nav a {
		text-decoration: none;
		color: #5f5a52;
	}

	.hero {
		min-height: 72vh;
		display: grid;
		align-content: center;
		padding: 48px clamp(20px, 8vw, 120px);
		max-width: 1040px;
	}

	.eyebrow {
		margin: 0 0 16px;
		color: #7b6f5f;
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
	}

	h1,
	h2,
	p,
	li,
	address {
		letter-spacing: 0;
	}

	h1 {
		margin: 0;
		font-size: clamp(44px, 8vw, 96px);
		line-height: 0.95;
		max-width: 980px;
	}

	h2 {
		margin: 0 0 20px;
		font-size: clamp(32px, 5vw, 56px);
		line-height: 1;
		max-width: 820px;
	}

	p,
	li,
	address {
		font-size: 18px;
		line-height: 1.7;
		max-width: 720px;
	}

	address {
		font-style: normal;
		color: #4f4a43;
	}

	.hero-text {
		margin: 28px 0 36px;
		color: #4f4a43;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.button {
		width: fit-content;
		border: 1px solid #1d1b18;
		padding: 14px 20px;
		text-decoration: none;
		font-weight: 700;
	}

	.button-secondary {
		background: transparent;
		color: #4f4a43;
		border-color: #b8afa2;
	}

	.section {
		padding: 96px clamp(20px, 8vw, 120px);
		border-top: 1px solid #ded8cf;
	}

	.section p:not(.eyebrow),
	.section li {
		color: #4f4a43;
	}

	.note {
		font-weight: 700;
	}

	.quote-list,
	.moment-list {
		padding-left: 20px;
	}

	.quote-list {
		list-style: none;
		padding-left: 0;
	}

	.statement {
		color: #1d1b18 !important;
		font-size: clamp(24px, 4vw, 40px);
		line-height: 1.2;
		font-weight: 700;
	}

	.intro,
	.promise,
	.compass,
	.philosophy {
		background: #f1ece3;
	}

	.contact {
		background: #ede6dc;
	}

	.footer {
		padding: 32px clamp(20px, 5vw, 72px);
		color: #6f675c;
	}

	.footer p {
		margin: 0 0 8px;
		font-size: 16px;
	}

	.footer nav {
		flex-wrap: wrap;
		margin-top: 18px;
	}

	@media (max-width: 720px) {
		.site-header {
			align-items: flex-start;
			flex-direction: column;
		}

		nav {
			flex-wrap: wrap;
		}

		.hero {
			min-height: 64vh;
		}
	}
</style>
