---
import BouquetShowcase from "../../components/BouquetShowcase.astro";
import MobileContactBar from "../../components/MobileContactBar.astro";
const siteUrl = "https://blumenkassel.de";
const canonicalUrl = `${siteUrl}/ru/`;
const germanUrl = `${siteUrl}/`;
const pageTitle = "Sisters Studio – Blumen Kassel | Авторские букеты ручной работы в Касселе";
const pageDescription =
	"Sisters Studio – Blumen Kassel создаёт авторские букеты ручной работы для особенных моментов. Индивидуальный подход, современная флористика и свежие цветы в Касселе.";
const ogTitle = "Sisters Studio – Blumen Kassel";
const ogDescription =
	"Авторские букеты, созданные с вниманием к каждой истории и каждому человеку.";
const phoneNumber = "+491602233298";
const phoneDisplay = "+49 160 2233298";
const whatsappUrl = "https://wa.me/491602233298";
const instagramUrl = "https://www.instagram.com/blumen.kassel/";
const routeUrl = "https://www.google.com/maps/search/?api=1&query=Wilhelmsh%C3%B6her%20Allee%2069%2C%2034121%20Kassel";

const floristSchema = {
	"@context": "https://schema.org",
	"@type": "Florist",
	"@id": `${germanUrl}#florist`,
	name: "Sisters Studio – Blumen Kassel",
	url: germanUrl,
	telephone: phoneNumber,
	description: pageDescription,
	address: {
		"@type": "PostalAddress",
		streetAddress: "Wilhelmshöher Allee 69",
		postalCode: "34121",
		addressLocality: "Kassel",
		addressCountry: "DE",
	},
	openingHoursSpecification: [
		{
			"@type": "OpeningHoursSpecification",
			dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			opens: "10:00",
			closes: "18:00",
		},
	],
	areaServed: {
		"@type": "City",
		name: "Kassel",
	},
	sameAs: [instagramUrl],
};
---

<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="de" href={germanUrl} />
		<link rel="alternate" hreflang="ru" href={canonicalUrl} />
		<link rel="alternate" hreflang="x-default" href={germanUrl} />

		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Sisters Studio – Blumen Kassel" />
		<meta property="og:locale" content="ru_RU" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />

		<script type="application/ld+json" set:html={JSON.stringify(floristSchema)} />
	</head>

	<body>
		<header class="site-header">
			<a class="brand" href="/ru/">Sisters Studio – Blumen Kassel</a>
			<nav aria-label="Основная навигация">
				<a href="#heute">Букеты в наличии</a>
				<a href="#ueber-uns">О нас</a>
				<a href="#kontakt">Контакты</a>
				<a href={instagramUrl}>Instagram</a>
				<span class="language-switch" aria-label="Выбор языка">
					<a href="/">DE</a>
					<a aria-current="page" href="/ru/">RU</a>
				</span>
			</nav>
		</header>

		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">Sisters Studio – Blumen Kassel</p>
					<h1>Букеты, которые говорят о ваших чувствах лучше любых слов.</h1>
					<p class="hero-text">
						Каждый букет начинается с истории. Мы не собираем цветы по шаблону — мы
						создаём композиции, которые помогают передать именно те чувства, которые
						вы хотите подарить.
					</p>
					<div class="actions">
						<a class="button" href="#heute">Смотреть букеты в наличии</a>
						<a class="button button-secondary" href="#kontakt">Связаться с нами</a>
					</div>
				</div>
				<figure class="hero-media">
					<img
						src="/images/bouquets/blush-rose-eustoma.webp"
						alt="Авторский букет с розовыми розами и белыми цветами"
					/>
				</figure>
			</section>

			<section class="section intro">
				<h2>Иногда один букет говорит больше, чем длинные слова.</h2>
				<p>
					Любовь, благодарность, день рождения, извинение или просто желание
					сделать чей-то день светлее — мы поможем подобрать букет, который будет
					говорить за вас.
				</p>
			</section>
			<BouquetShowcase locale="ru" />

			<section id="ueber-uns" class="section">
				<p class="eyebrow">О нас</p>
				<h2>Две сестры. Одна студия. Сотни историй.</h2>
				<p>
					Sisters Studio – Blumen Kassel — это современная цветочная мастерская,
					созданная двумя сёстрами.
				</p>
				<p>
					Мы не делаем массовые букеты. Каждый букет создаётся для конкретного
					человека и конкретного момента.
				</p>
				<p>Поэтому мы редко начинаем разговор с вопроса:</p>
				<p>«Какие цветы вы хотите?»</p>
				<p>Гораздо чаще мы спрашиваем:</p>
				<p>«Для кого этот букет?»</p>
				<p>Потому что для нас букет — это не просто цветы.</p>
				<p>Это способ сказать человеку то, что иногда трудно выразить словами.</p>
			</section>

			<section class="section">
				<p class="eyebrow">Почему выбирают нас</p>
				<h2>Почему к нам возвращаются</h2>
				<p>Люди приходят к нам не просто за цветами.</p>
				<p>Они приходят, когда хотят сделать чей-то день особенным.</p>
				<p>Когда хочется сказать:</p>
				<ul class="quote-list">
					<li>«Я люблю тебя.»</li>
					<li>«Спасибо.»</li>
					<li>«Прости.»</li>
					<li>«Я рядом.»</li>
					<li>«Ты для меня важен.»</li>
				</ul>
				<p>
					Наша задача — помочь выразить эти чувства красиво, искренне и именно так,
					как вы задумали.
				</p>
			</section>

			<section class="section promise">
				<p class="eyebrow">Наше обещание</p>
				<h2>Наше обещание</h2>
				<p>Мы хотим, чтобы, выходя из нашей студии, вы были абсолютно уверены:</p>
				<p class="statement">«Да. Именно это я хотел сказать этим букетом.»</p>
				<p>
					Для нас хороший букет — это тот, который подходит не только по цвету, но и
					по человеку, поводу и эмоциям.
				</p>
			</section>

			<section class="section moments">
				<p class="eyebrow">Для каких случаев</p>
				<h2>Для моментов, которые хочется запомнить</h2>
				<p>Мы создаём букеты для:</p>
				<ul class="moment-list">
					<li>Дней рождения</li>
					<li>Признаний в любви</li>
					<li>Благодарности</li>
					<li>Извинений</li>
					<li>Свадеб</li>
					<li>Неожиданных сюрпризов</li>
					<li>Маленьких знаков внимания</li>
					<li>И всех тех случаев, когда нет повода, кроме желания сделать кого-то счастливее</li>
				</ul>
			</section>

			<section class="section compass">
				<p class="eyebrow">Наш подход</p>
				<h2>Наш ориентир</h2>
				<p>Перед каждым букетом мы задаём себе один простой вопрос:</p>
				<p class="statement">
					«Поможет ли эта композиция передать чувства человека именно так, как он
					хотел?»
				</p>
				<p>Если ответ — «да», значит мы движемся в правильном направлении.</p>
				<p>
					Эта идея лежит в основе всего, что мы делаем: общения с клиентами, выбора
					цветов, оформления букета и каждой детали.
				</p>
			</section>

			<section class="section philosophy">
				<p class="eyebrow">Во что мы верим</p>
				<h2>Во что мы верим</h2>
				<p>Мы убеждены, что люди приходят не просто за цветами.</p>
				<p>Они приходят с чувствами, которые хотят передать близкому человеку.</p>
				<p>
					Иногда это любовь.<br />
					Иногда благодарность.<br />
					Иногда поддержка.<br />
					Иногда просто желание сделать чей-то день немного счастливее.
				</p>
				<p>Наша задача — помочь этим чувствам обрести форму.</p>
				<p>Поэтому каждый букет в Sisters Studio начинается не с цветов.</p>
				<p>Он начинается с человека.</p>
			</section>

			<section class="section">
				<p class="eyebrow">Instagram</p>
				<h2>Наши последние работы</h2>
				<p>Большинство наших букетов существуют только один раз.</p>
				<p>
					В Instagram мы делимся свежими работами, показываем жизнь студии и
					рассказываем истории, которые стоят за цветами.
				</p>
				<a class="button" href={instagramUrl}>Открыть Instagram</a>
			</section>

			<section id="kontakt" class="section contact">
				<p class="eyebrow">Контакты</p>
				<h2>Расскажите нам, для кого этот букет</h2>
				<p>
					Мы с удовольствием поможем подобрать цветы для любого важного события.
				</p>
				<p>
					Позвоните нам, напишите в WhatsApp или приходите в студию — мы всегда рады
					помочь.
				</p>
				<address>
					Sisters Studio – Blumen Kassel<br />
					Wilhelmshöher Allee 69<br />
					34121 Kassel
				</address>
				<p>
					<a href={`tel:${phoneNumber}`}>{phoneDisplay}</a>
				</p>
				<div class="actions">
					<a class="button" href={whatsappUrl}>Написать в WhatsApp</a>
					<a class="button button-secondary" href={routeUrl}>Построить маршрут</a>
				</div>
			</section>
		</main>

		<MobileContactBar locale="ru" />

		<footer class="footer">
			<p>Sisters Studio – Blumen Kassel</p>
			<p>Авторские букеты ручной работы в Касселе.</p>
			<nav aria-label="Навигация в футере">
				<a href="/ru/">Главная</a>
				<a href="#heute">Букеты в наличии</a>
				<a href="#ueber-uns">О нас</a>
				<a href="#kontakt">Контакты</a>
				<a href={instagramUrl}>Instagram</a>
				<a href="/impressum/">Impressum</a>
				<a href="/datenschutz/">Datenschutz</a>
			</nav>
		</footer>
	</body>
</html>

<style>
	:root {
		color: #1d1b18;
		background: #f8f5ef;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	body {
		margin: 0;
		background: #f8f5ef;
		color: #1d1b18;
	}

	a {
		color: inherit;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 24px clamp(20px, 5vw, 72px);
	}

	.brand {
		font-weight: 700;
		text-decoration: none;
	}

	nav {
		display: flex;
		gap: 20px;
		font-size: 14px;
	}

	nav a {
		text-decoration: none;
		color: #5f5a52;
	}

	.language-switch {
		display: inline-flex;
		gap: 8px;
		color: #5f5a52;
	}

	.language-switch a[aria-current="page"] {
		color: #1d1b18;
		font-weight: 700;
	}

	.hero {
		min-height: 72vh;
		display: grid;
		align-content: center;
		padding: 48px clamp(20px, 8vw, 120px);
		max-width: 1040px;
	}

	.eyebrow {
		margin: 0 0 16px;
		color: #7b6f5f;
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
	}

	h1,
	h2,
	p,
	li,
	address {
		letter-spacing: 0;
	}

	h1 {
		margin: 0;
		font-size: clamp(44px, 8vw, 96px);
		line-height: 0.95;
		max-width: 980px;
	}

	h2 {
		margin: 0 0 20px;
		font-size: clamp(32px, 5vw, 56px);
		line-height: 1;
		max-width: 820px;
	}

	p,
	li,
	address {
		font-size: 18px;
		line-height: 1.7;
		max-width: 720px;
	}

	address {
		font-style: normal;
		color: #4f4a43;
	}

	.hero-text {
		margin: 28px 0 36px;
		color: #4f4a43;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.button {
		width: fit-content;
		border: 1px solid #1d1b18;
		padding: 14px 20px;
		text-decoration: none;
		font-weight: 700;
	}

	.button-secondary {
		background: transparent;
		color: #4f4a43;
		border-color: #b8afa2;
	}

	.section {
		padding: 96px clamp(20px, 8vw, 120px);
		border-top: 1px solid #ded8cf;
	}

	.section p:not(.eyebrow),
	.section li {
		color: #4f4a43;
	}

	.note {
		font-weight: 700;
	}

	.quote-list,
	.moment-list {
		padding-left: 20px;
	}

	.quote-list {
		list-style: none;
		padding-left: 0;
	}

	.statement {
		color: #1d1b18 !important;
		font-size: clamp(24px, 4vw, 40px);
		line-height: 1.2;
		font-weight: 700;
	}

	.intro,
	.promise,
	.compass,
	.philosophy {
		background: #f1ece3;
	}

	.contact {
		background: #ede6dc;
	}

	.footer {
		padding: 32px clamp(20px, 5vw, 72px);
		color: #6f675c;
	}

	.footer p {
		margin: 0 0 8px;
		font-size: 16px;
	}

	.footer nav {
		flex-wrap: wrap;
		margin-top: 18px;
	}

	@media (max-width: 720px) {
		.site-header {
			align-items: flex-start;
			flex-direction: column;
		}

		nav {
			flex-wrap: wrap;
		}

		.hero {
			min-height: 64vh;
		}
	}
	/* Mobile-first visual foundation */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 18px clamp(20px, 5vw, 72px);
		border-bottom: 1px solid rgba(222, 216, 207, 0.72);
		background: rgba(248, 245, 239, 0.88);
		backdrop-filter: blur(18px);
	}

	.hero {
		display: grid;
		grid-template-columns: 1fr;
		align-items: center;
		align-content: initial;
		gap: 32px;
		min-height: calc(100svh - 74px);
		max-width: 1280px;
		padding: 32px clamp(20px, 7vw, 112px) 72px;
	}

	.hero-copy {
		max-width: 760px;
	}

	.hero-media {
		margin: 0;
	}

	.hero-media img {
		display: block;
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: 0 24px 80px rgba(29, 27, 24, 0.12);
	}

	.button {
		border-radius: 8px;
		background: #1d1b18;
		color: #fffdf8;
	}

	.button-secondary {
		background: transparent;
		color: #4f4a43;
	}

	@media (min-width: 860px) {
		.hero {
			grid-template-columns: minmax(0, 0.92fr) minmax(360px, 0.72fr);
			min-height: calc(100vh - 74px);
		}
	}

	@media (max-width: 720px) {
		.site-header {
			padding-block: 14px;
		}

		nav {
			gap: 14px;
		}

		.hero {
			min-height: auto;
			padding-top: 24px;
		}

		.hero-media {
			order: -1;
		}
	}
</style>
