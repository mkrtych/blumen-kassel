---
type Locale = "de" | "ru";

const { locale = "de" } = Astro.props as { locale?: Locale };
const whatsappUrl = "https://wa.me/491602233298";
const routeUrl = "https://www.google.com/maps/search/?api=1&query=Wilhelmsh%C3%B6her%20Allee%2069%2C%2034121%20Kassel";

const labels = {
	de: {
		aria: "Schneller Kontakt",
		whatsapp: "WhatsApp",
		route: "Kommt vorbei",
	},
	ru: {
		aria: "Быстрый контакт",
		whatsapp: "WhatsApp",
		route: "Приходите к нам",
	},
}[locale];
---

<nav class="mobile-contact-bar" aria-label={labels.aria}>
	<a class="quick-action quick-action-icon" href={whatsappUrl} aria-label={labels.whatsapp}>
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<path d="M5.4 18.6 6.3 15A7.4 7.4 0 1 1 9 17.7l-3.6.9Z"></path>
			<path d="M9.2 8.7c.2 2.7 1.7 4.8 4.4 6 .6.3 1.2-.3 1.5-.9"></path>
		</svg>
	</a>
	<a class="quick-action quick-action-route" href={routeUrl}>
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<path d="M5 14 7 8.8A2.5 2.5 0 0 1 9.3 7h5.4A2.5 2.5 0 0 1 17 8.8L19 14"></path>
			<path d="M4 14h16v4H4z"></path>
			<path d="M7 18v1.5M17 18v1.5M7 14h.01M17 14h.01"></path>
		</svg>
		<span>{labels.route}</span>
	</a>
</nav>

<style is:global>
	@media (max-width: 759px) {
		body {
			padding-bottom: 58px;
		}
	}
</style>

<style>
	.mobile-contact-bar {
		display: none;
	}

	@media (max-width: 759px) {
		.mobile-contact-bar {
			position: fixed;
			right: 12px;
			bottom: 10px;
			left: 12px;
			z-index: 20;
			display: flex;
			justify-content: space-between;
			gap: 10px;
			pointer-events: none;
		}

		.quick-action {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 38px;
			color: #1d1b18;
			font-family: "Helvetica Neue", Arial, Helvetica, sans-serif;
			font-size: 13px;
			font-weight: 300;
			line-height: 1;
			text-decoration: none;
			pointer-events: auto;
		}

		.quick-action-icon {
			width: 42px;
			border-radius: 999px;
			background: rgba(248, 245, 239, 0.34);
			backdrop-filter: blur(10px);
		}

		.quick-action-route {
			gap: 7px;
			padding: 0 10px;
			border-radius: 999px;
			background: rgba(248, 245, 239, 0.34);
			backdrop-filter: blur(10px);
		}

		.quick-action svg {
			width: 18px;
			height: 18px;
			fill: none;
			stroke: currentColor;
			stroke-linecap: round;
			stroke-linejoin: round;
			stroke-width: 1.45;
		}
	}
</style>