---
import { authorBouquets, classicFlowers } from "../data/bouquets";

type Locale = "de" | "ru";

const { locale = "de" } = Astro.props as { locale?: Locale };
const siteUrl = "https://blumenkassel.de";
const pagePath = locale === "ru" ? "/ru/" : "/";
const lang = locale;

const labels = {
	de: {
		eyebrow: "Heute verfügbar",
		title: "Heute im Studio",
		intro:
			"Frisch gebundene Sträuße und klassische Blumen, die heute im Studio verfügbar sind.",
		authorButton: "Autorensträuße",
		classicButton: "Klassische Blumen",
		authorTitle: "Autorensträuße",
		authorText:
			"Einmalige Sträuße, die heute von Hand gebunden wurden. Verkauftes bleibt bis Tagesende sichtbar und kann als Inspiration dienen.",
		classicTitle: "Klassische Blumen",
		classicText:
			"Klare Auswahl für Rosen, Chrysanthemen und andere Blumen nach Stückzahl. Für aktuelle Verfügbarkeit schreiben Sie uns direkt.",
		available: "Heute verfügbar",
		reserved: "Reserviert",
		sold: "Verkauft",
		limited: "Begrenzt verfügbar",
		unavailable: "Nicht verfügbar",
		ask: "Per WhatsApp anfragen",
		askSimilar: "Ähnlichen Strauß anfragen",
		askClassic: "Verfügbarkeit anfragen",
	},
	ru: {
		eyebrow: "Сегодня в наличии",
		title: "Сегодня в студии",
		intro:
			"Свежие авторские букеты и классические цветы, которые сегодня доступны в студии.",
		authorButton: "Авторские букеты",
		classicButton: "Классические цветы",
		authorTitle: "Авторские букеты",
		authorText:
			"Уникальные букеты, собранные сегодня вручную. Проданные букеты остаются видимыми до конца дня и могут служить вдохновением.",
		classicTitle: "Классические цветы",
		classicText:
			"Понятный выбор роз, хризантем и других цветов по количеству. Чтобы узнать наличие прямо сейчас, напишите нам.",
		available: "Сегодня в наличии",
		reserved: "Зарезервировано",
		sold: "Продано",
		limited: "Ограниченно в наличии",
		unavailable: "Нет в наличии",
		ask: "Спросить в WhatsApp",
		askSimilar: "Спросить похожий букет",
		askClassic: "Уточнить наличие",
	},
}[lang];

const statusLabels = {
	available: labels.available,
	reserved: labels.reserved,
	sold: labels.sold,
	archived: "Archiv",
	limited: labels.limited,
	unavailable: labels.unavailable,
};

const buildWhatsAppUrl = (message: string) =>
	`https://wa.me/491602233298?text=${encodeURIComponent(message)}`;

const bouquetMessage = (bouquet: (typeof authorBouquets)[number]) => {
	const url = `${siteUrl}${pagePath}#${bouquet.id}`;
	if (lang === "ru") {
		return bouquet.status === "sold"
			? `Здравствуйте, этот букет уже продан. Можно ли сделать похожий? ${url}`
			: `Здравствуйте, меня интересует этот букет: ${url} Он сегодня ещё в наличии?`;
	}

	return bouquet.status === "sold"
		? `Hallo Sisters Studio, dieser Strauß ist bereits verkauft. Können Sie etwas Ähnliches gestalten? ${url}`
		: `Hallo Sisters Studio, ich interessiere mich für diesen Strauß: ${url} Ist er heute noch verfügbar?`;
};

const classicMessage = (flower: (typeof classicFlowers)[number]) => {
	if (lang === "ru") {
		return `Здравствуйте, меня интересуют ${flower.title.ru}. Что сегодня есть в наличии?`;
	}

	return `Hallo Sisters Studio, ich interessiere mich für ${flower.title.de}. Was ist heute verfügbar?`;
};
---

<section id="heute" class="section showcase-section">
	<p class="eyebrow">{labels.eyebrow}</p>
	<h2>{labels.title}</h2>
	<p>{labels.intro}</p>

	<div class="showcase-tabs" aria-label={labels.title}>
		<a href="#author-bouquets">{labels.authorButton}</a>
		<a href="#classic-flowers">{labels.classicButton}</a>
	</div>

	<div id="author-bouquets" class="showcase-group">
		<div class="showcase-heading">
			<h3>{labels.authorTitle}</h3>
			<p>{labels.authorText}</p>
		</div>

		<div class="bouquet-rail" aria-label={labels.authorTitle}>
			{authorBouquets.map((bouquet) => (
				<article id={bouquet.id} class={`bouquet-card status-${bouquet.status}`}>
					<a class="card-anchor" href={`#${bouquet.id}`} aria-label={bouquet.title[lang]}>
						<img src={bouquet.image} alt={bouquet.imageAlt[lang]} loading="lazy" />
					</a>
					<div class="card-body">
						<div class="card-meta">
							<span class="status-pill">{statusLabels[bouquet.status]}</span>
							<span class="price">{bouquet.price}</span>
						</div>
						<h4>{bouquet.title[lang]}</h4>
						<p>{bouquet.description[lang]}</p>
						<a class="card-action" href={buildWhatsAppUrl(bouquetMessage(bouquet))}>
							{bouquet.status === "sold" ? labels.askSimilar : labels.ask}
						</a>
					</div>
				</article>
			))}
		</div>
	</div>

	<div id="classic-flowers" class="showcase-group classic-group">
		<div class="showcase-heading">
			<h3>{labels.classicTitle}</h3>
			<p>{labels.classicText}</p>
		</div>

		<div class="classic-grid" aria-label={labels.classicTitle}>
			{classicFlowers.map((flower) => (
				<article id={flower.id} class={`classic-card status-${flower.status}`}>
					<div>
						<span class="status-pill">{statusLabels[flower.status]}</span>
						<h4>{flower.title[lang]}</h4>
						<p>{flower.description[lang]}</p>
					</div>
					<ul>
						{flower.variants.map((variant) => (
							<li>
								<span>{variant.label[lang]}</span>
								<strong>{variant.price}</strong>
							</li>
						))}
					</ul>
					<a class="card-action" href={buildWhatsAppUrl(classicMessage(flower))}>{labels.askClassic}</a>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.showcase-section {
		background: #fbf8f2;
		border-top: 1px solid #ded8cf;
		padding: 72px clamp(20px, 8vw, 120px);
	}

	.eyebrow {
		margin: 0 0 16px;
		color: #7b6f5f;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.showcase-section h2 {
		margin: 0 0 20px;
		font-size: clamp(32px, 5vw, 56px);
		letter-spacing: 0;
		line-height: 1;
		max-width: 820px;
	}

	.showcase-section p {
		color: #4f4a43;
		font-size: 18px;
		letter-spacing: 0;
		line-height: 1.7;
		max-width: 720px;
	}

	.showcase-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin: 32px 0 56px;
	}

	.showcase-tabs a,
	.card-action {
		border: 1px solid #1d1b18;
		color: #1d1b18;
		font-weight: 700;
		text-decoration: none;
	}

	.showcase-tabs a {
		padding: 14px 18px;
	}

	.showcase-heading {
		margin-bottom: 24px;
	}

	.showcase-heading h3 {
		margin: 0 0 12px;
		font-size: clamp(28px, 4vw, 44px);
		letter-spacing: 0;
		line-height: 1;
	}

	.bouquet-rail {
		display: grid;
		grid-auto-columns: minmax(260px, 82vw);
		grid-auto-flow: column;
		gap: 18px;
		overflow-x: auto;
		padding: 4px 20px 24px 0;
		scroll-snap-type: x mandatory;
	}

	.bouquet-card,
	.classic-card {
		background: #fffdf8;
		border: 1px solid #ded8cf;
		border-radius: 8px;
		overflow: hidden;
		scroll-margin-top: 96px;
	}

	.bouquet-card {
		scroll-snap-align: start;
	}

	.bouquet-card:target,
	.classic-card:target {
		border-color: #7a8b66;
		box-shadow: 0 0 0 3px rgba(122, 139, 102, 0.18);
	}

	.bouquet-card img {
		aspect-ratio: 1 / 1;
		display: block;
		width: 100%;
		height: auto;
		object-fit: cover;
	}

	.card-body,
	.classic-card {
		padding: 18px;
	}

	.card-meta,
	.classic-card li {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.status-pill {
		display: inline-flex;
		width: fit-content;
		background: #edf1e6;
		color: #46573a;
		font-size: 13px;
		font-weight: 700;
		padding: 6px 10px;
		border-radius: 999px;
	}

	.status-sold .status-pill,
	.status-unavailable .status-pill {
		background: #efe4de;
		color: #7a4632;
	}

	.status-reserved .status-pill,
	.status-limited .status-pill {
		background: #f4ead4;
		color: #755c1f;
	}

	.price {
		font-weight: 800;
	}

	.bouquet-card h4,
	.classic-card h4 {
		margin: 14px 0 8px;
		font-size: 24px;
		letter-spacing: 0;
		line-height: 1.1;
	}

	.bouquet-card p,
	.classic-card p {
		font-size: 16px;
		line-height: 1.55;
	}

	.card-action {
		display: inline-flex;
		margin-top: 12px;
		padding: 12px 14px;
	}

	.classic-group {
		margin-top: 72px;
	}

	.classic-grid {
		display: grid;
		gap: 16px;
	}

	.classic-card ul {
		list-style: none;
		margin: 18px 0 0;
		padding: 0;
	}

	.classic-card li {
		border-top: 1px solid #e8e1d6;
		padding: 10px 0;
		font-size: 16px;
	}

	@media (min-width: 760px) {
		.bouquet-rail {
			grid-auto-flow: initial;
			grid-auto-columns: initial;
			grid-template-columns: repeat(4, minmax(0, 1fr));
			overflow: visible;
			padding-right: 0;
		}

		.classic-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>

