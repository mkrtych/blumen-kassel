---
import { authorBouquets, roseProducts, seasonalFlowers, type FlowerProduct } from "../data/bouquets";

type Locale = "de" | "ru";

const { locale = "de" } = Astro.props as { locale?: Locale };
const siteUrl = "https://blumenkassel.de";
const pagePath = locale === "ru" ? "/ru/" : "/";
const lang = locale;

const labels = {
	de: {
		eyebrow: "Heute verfügbar",
		title: "Heute im Studio",
		introTitle: "Blumen, die sagen, was Worte manchmal nicht können.",
		intro:
			"Ob Geburtstag, Liebe, Dankbarkeit, Entschuldigung oder ein schöner Moment zwischendurch: hier finden Sie Sträuße und Blumen, die heute im Studio verfügbar sind.",
		authorTitle: "Autorensträuße",
		authorText:
			"Einmalige Sträuße, die heute von Hand gebunden wurden. Verkauftes bleibt bis Tagesende sichtbar und kann als Inspiration dienen.",
		roseTitle: "Rosen",
		roseText: "Klassische Rosen nach Stückzahl. Die aktuelle Auswahl kann je nach Tagesbestand variieren.",
		seasonalTitle: "Saisonale Blumen",
		seasonalText: "Frische Blumen der Saison für kleine Gesten, Ergänzungen oder eigene Zusammenstellungen.",
		available: "Verfügbar",
		reserved: "Reserviert",
		sold: "Verkauft",
		limited: "Begrenzt",
		unavailable: "Nicht verfügbar",
		ask: "Fragen",
		askSimilar: "Fragen",
		openDetails: "Details ansehen",
	},
	ru: {
		eyebrow: "Сегодня в наличии",
		title: "Сегодня в студии",
		introTitle: "Иногда один букет говорит больше, чем длинные слова.",
		intro:
			"Любовь, благодарность, день рождения, извинение или желание сделать чей-то день светлее: здесь собраны букеты и цветы, которые сегодня доступны в студии.",
		authorTitle: "Авторские букеты",
		authorText:
			"Уникальные букеты, собранные сегодня вручную. Проданные букеты остаются видимыми до конца дня и могут служить вдохновением.",
		roseTitle: "Розы",
		roseText: "Классические розы по количеству. Актуальный выбор зависит от наличия в студии.",
		seasonalTitle: "Сезонные цветы",
		seasonalText: "Свежие сезонные цветы для небольших жестов, дополнений или индивидуальных композиций.",
		available: "В наличии",
		reserved: "Резерв",
		sold: "Продано",
		limited: "Ограниченно",
		unavailable: "Нет в наличии",
		ask: "Спросить",
		askSimilar: "Спросить",
		openDetails: "Смотреть детали",
	},
}[lang];

const statusLabels = {
	available: labels.available,
	reserved: labels.reserved,
	sold: labels.sold,
	archived: "Archiv",
	limited: labels.limited,
	unavailable: labels.unavailable,
};

const buildWhatsAppUrl = (message: string) =>
	`https://wa.me/491602233298?text=${encodeURIComponent(message)}`;

const bouquetMessage = (bouquet: (typeof authorBouquets)[number]) => {
	const url = `${siteUrl}${pagePath}#${bouquet.id}`;
	if (lang === "ru") {
		return bouquet.status === "sold"
			? `Здравствуйте, букет ${bouquet.code} уже продан. Можно ли сделать похожий? ${url}`
			: `Здравствуйте, меня интересует букет ${bouquet.code}: ${url} Он сегодня ещё в наличии?`;
	}

	return bouquet.status === "sold"
		? `Hallo Sisters Studio, der Strauß ${bouquet.code} ist bereits verkauft. Können Sie etwas Ähnliches gestalten? ${url}`
		: `Hallo Sisters Studio, ich interessiere mich für Strauß ${bouquet.code}: ${url} Ist er heute noch verfügbar?`;
};

const productMessage = (product: FlowerProduct) => {
	if (lang === "ru") {
		return `Здравствуйте, меня интересует: ${product.title.ru}. Что сегодня есть в наличии?`;
	}

	return `Hallo Sisters Studio, ich interessiere mich für ${product.title.de}. Was ist heute verfügbar?`;
};
---

<section id="heute" class="section showcase-section">
	<div class="showcase-intro">
		<p class="eyebrow">{labels.eyebrow}</p>
		<h2>{labels.introTitle}</h2>
		<p>{labels.intro}</p>
	</div>

	<div id="author-bouquets" class="showcase-group snap-panel">
		<div class="showcase-heading">
			<p class="eyebrow">{labels.title}</p>
			<h3>{labels.authorTitle}</h3>
			<p>{labels.authorText}</p>
		</div>

		<div class="product-rail author-rail" aria-label={labels.authorTitle}>
			{authorBouquets.map((bouquet) => (
				<article id={bouquet.id} class={`product-card author-card status-${bouquet.status}`}>
					<a class="card-anchor" href={`#${bouquet.id}`} aria-label={`${labels.openDetails}: ${bouquet.code}`}>
						<img src={bouquet.image} alt={bouquet.imageAlt[lang]} loading="lazy" />
					</a>
					<div class="card-body">
						<div class="card-meta">
							<span class="status-pill">{statusLabels[bouquet.status]}</span>
							<span class="price">{bouquet.price}</span>
						</div>
						<h4>{bouquet.code}</h4>
						<a class="card-action" href={buildWhatsAppUrl(bouquetMessage(bouquet))}>
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="M5.4 18.6 6.3 15A7.4 7.4 0 1 1 9 17.7l-3.6.9Z"></path>
								<path d="M9.2 8.7c.2 2.7 1.7 4.8 4.4 6 .6.3 1.2-.3 1.5-.9"></path>
							</svg>
							<span>{bouquet.status === "sold" ? labels.askSimilar : labels.ask}</span>
						</a>
					</div>
				</article>
			))}
		</div>
	</div>

	<div id="classic-flowers" class="showcase-group snap-panel">
		<div class="showcase-heading">
			<h3>{labels.roseTitle}</h3>
			<p>{labels.roseText}</p>
		</div>

		<div class="product-rail" aria-label={labels.roseTitle}>
			{roseProducts.map((product) => (
				<article id={product.id} class={`product-card flower-card status-${product.status}`}>
					<img src={product.image} alt={product.imageAlt[lang]} loading="lazy" />
					<div class="card-body">
						<div class="card-meta">
							<span class="status-pill">{statusLabels[product.status]}</span>
						</div>
						<h4>{product.title[lang]}</h4>
						<ul>
							{product.variants.map((variant) => (
								<li>
									<span>{variant.label[lang]}</span>
									<strong>{variant.price}</strong>
								</li>
							))}
						</ul>
						<a class="card-action" href={buildWhatsAppUrl(productMessage(product))}>
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="M5.4 18.6 6.3 15A7.4 7.4 0 1 1 9 17.7l-3.6.9Z"></path>
								<path d="M9.2 8.7c.2 2.7 1.7 4.8 4.4 6 .6.3 1.2-.3 1.5-.9"></path>
							</svg>
							<span>{labels.ask}</span>
						</a>
					</div>
				</article>
			))}
		</div>
	</div>

	<div id="seasonal-flowers" class="showcase-group snap-panel">
		<div class="showcase-heading">
			<h3>{labels.seasonalTitle}</h3>
			<p>{labels.seasonalText}</p>
		</div>

		<div class="product-rail" aria-label={labels.seasonalTitle}>
			{seasonalFlowers.map((product) => (
				<article id={product.id} class={`product-card flower-card status-${product.status}`}>
					<img src={product.image} alt={product.imageAlt[lang]} loading="lazy" />
					<div class="card-body">
						<div class="card-meta">
							<span class="status-pill">{statusLabels[product.status]}</span>
						</div>
						<h4>{product.title[lang]}</h4>
						<ul>
							{product.variants.map((variant) => (
								<li>
									<span>{variant.label[lang]}</span>
									<strong>{variant.price}</strong>
								</li>
							))}
						</ul>
						<a class="card-action" href={buildWhatsAppUrl(productMessage(product))}>
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="M5.4 18.6 6.3 15A7.4 7.4 0 1 1 9 17.7l-3.6.9Z"></path>
								<path d="M9.2 8.7c.2 2.7 1.7 4.8 4.4 6 .6.3 1.2-.3 1.5-.9"></path>
							</svg>
							<span>{labels.ask}</span>
						</a>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.showcase-section {
		background: #fbf8f2;
		border-top: 1px solid #ded8cf;
		padding: 40px clamp(16px, 6vw, 96px) 64px;
		scroll-snap-align: start;
	}

	.showcase-intro {
		max-width: 860px;
		margin-bottom: 30px;
	}

	.eyebrow {
		margin: 0 0 10px;
		color: #7b6f5f;
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.showcase-section h2 {
		margin: 0 0 14px;
		font-size: clamp(30px, 5vw, 58px);
		letter-spacing: 0;
		line-height: 1;
		max-width: 840px;
		text-transform: uppercase;
	}

	.showcase-section p {
		color: #4f4a43;
		font-size: 17px;
		letter-spacing: 0;
		line-height: 1.55;
		max-width: 760px;
	}

	.showcase-group {
		margin-top: 54px;
		scroll-margin-top: 72px;
	}

	.snap-panel {
		scroll-snap-align: start;
	}

	.showcase-heading {
		margin-bottom: 18px;
	}

	.showcase-heading h3 {
		margin: 0 0 10px;
		font-size: clamp(26px, 4vw, 44px);
		letter-spacing: 0;
		line-height: 1;
		text-transform: uppercase;
	}

	.product-rail {
		display: grid;
		grid-auto-columns: minmax(220px, 72vw);
		grid-auto-flow: column;
		gap: 14px;
		overflow-x: auto;
		padding: 2px 18px 22px 0;
		scroll-padding-left: 2px;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
	}

	.product-card {
		background: #fffdf8;
		border: 1px solid #e1dacf;
		border-radius: 8px;
		overflow: hidden;
		scroll-margin-top: 92px;
		scroll-snap-align: start;
	}

	.product-card:target {
		border-color: #7a8b66;
		box-shadow: 0 0 0 3px rgba(122, 139, 102, 0.18);
	}

	.product-card img {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
	}

	.flower-card img {
		aspect-ratio: 1 / 1;
	}

	.card-body {
		display: grid;
		gap: 12px;
		padding: 14px;
	}

	.card-meta,
	.product-card li {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.status-pill {
		display: inline-flex;
		width: fit-content;
		background: #edf1e6;
		color: #46573a;
		font-size: 12px;
		font-weight: 800;
		padding: 5px 8px;
		border-radius: 999px;
		text-transform: uppercase;
	}

	.status-sold .status-pill,
	.status-unavailable .status-pill {
		background: #efe4de;
		color: #7a4632;
	}

	.status-reserved .status-pill,
	.status-limited .status-pill {
		background: #f4ead4;
		color: #755c1f;
	}

	.price {
		font-weight: 900;
	}

	.product-card h4 {
		margin: 0;
		font-size: 24px;
		letter-spacing: 0;
		line-height: 1;
		text-transform: uppercase;
	}

	.product-card ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.product-card li {
		border-top: 1px solid #e8e1d6;
		padding: 9px 0;
		font-size: 15px;
	}

	.card-action {
		display: grid;
		min-height: 42px;
		place-items: center;
		width: 100%;
		background: #1d1b18;
		border-radius: 8px;
		color: #fffdf8;
		font-size: 14px;
		font-weight: 800;
		text-align: center;
		text-decoration: none;
		text-transform: uppercase;
	}

	@media (min-width: 760px) {
		.showcase-section {
			padding-top: 56px;
		}

		.product-rail {
			grid-auto-columns: minmax(240px, 24vw);
			gap: 18px;
		}
	}

	@media (min-width: 1180px) {
		.product-rail {
			grid-auto-columns: minmax(250px, 1fr);
		}
	}
	/* Typography tune */
	.showcase-section h2 {
		max-width: 720px;
		font-size: clamp(26px, 3.8vw, 42px);
		line-height: 1.05;
	}

	.showcase-heading h3 {
		font-size: clamp(24px, 3vw, 34px);
		line-height: 1.05;
	}

	.showcase-section p {
		font-size: clamp(16px, 1.6vw, 18px);
		line-height: 1.58;
	}
	/* Softer typography pass */
	.showcase-section h2,
	.showcase-heading h3,
	.product-card h4 {
		font-weight: 600;
		text-transform: none;
	}

	.showcase-section h2 {
		max-width: 660px;
		font-size: clamp(23px, 3vw, 34px);
		line-height: 1.12;
	}

	.showcase-heading h3 {
		font-size: clamp(22px, 2.6vw, 30px);
		line-height: 1.12;
	}

	.showcase-section p {
		font-size: clamp(15px, 1.35vw, 17px);
		line-height: 1.6;
	}

	.product-card h4 {
		font-size: 20px;
	}

	.card-action,
	.status-pill {
		font-weight: 700;
	}
	/* Editorial rhythm pass */
	.showcase-section {
		padding: clamp(46px, 7vw, 78px) clamp(18px, 6vw, 96px) clamp(52px, 7vw, 86px);
	}

	.showcase-intro {
		max-width: 680px;
		margin-bottom: 28px;
	}

	.showcase-section h2,
	.showcase-heading h3,
	.product-card h4 {
		font-weight: 500;
		text-transform: none;
	}

	.showcase-section h2 {
		max-width: 640px;
		font-size: clamp(28px, 3.1vw, 40px);
		line-height: 1.12;
	}

	.showcase-heading h3 {
		font-size: clamp(22px, 2.2vw, 28px);
		line-height: 1.16;
	}

	.showcase-section p {
		max-width: 640px;
		font-size: clamp(16px, 1.25vw, 18px);
		line-height: 1.62;
	}

	.showcase-group {
		margin-top: clamp(38px, 5vw, 56px);
	}

	.product-card h4 {
		font-size: 20px;
	}

	@media (max-width: 720px) {
		.showcase-section {
			padding-top: 42px;
		}

		.showcase-section h2 {
			font-size: clamp(26px, 7vw, 34px);
		}
	}

	/* Atelier showcase typography */
	.showcase-section {
		padding-top: clamp(38px, 6vw, 68px);
	}

	.showcase-intro {
		max-width: 620px;
	}

	.showcase-section .eyebrow {
		font-size: 10px;
		font-weight: 300;
		line-height: 1.2;
		letter-spacing: 0;
		color: rgba(95, 90, 82, 0.82);
	}

	.showcase-section h2,
	.showcase-heading h3,
	.product-card h4 {
		font-family: Georgia, "Times New Roman", serif;
		font-weight: 400;
		letter-spacing: 0;
		text-transform: none;
	}

	.showcase-section h2 {
		max-width: 620px;
		font-size: clamp(25px, 2.8vw, 36px);
		line-height: 1.13;
	}

	.showcase-heading h3 {
		font-size: clamp(22px, 2.2vw, 28px);
		line-height: 1.14;
	}

	.showcase-section p {
		max-width: 600px;
		font-size: clamp(15px, 1.2vw, 16.5px);
		font-weight: 300;
		line-height: 1.7;
	}

	.product-card h4 {
		font-size: 19px;
		line-height: 1.18;
	}

	.product-card li,
	.card-meta,
	.price {
		font-weight: 300;
	}

	.card-action,
	.status-pill {
		font-size: 12px;
		font-weight: 400;
		letter-spacing: 0;
	}

	@media (max-width: 720px) {
		.showcase-section {
			padding-top: 36px;
		}

		.showcase-intro {
			max-width: 320px;
		}

		.showcase-section h2 {
			font-size: clamp(24px, 6.4vw, 30px);
			line-height: 1.14;
		}

		.showcase-heading h3 {
			font-size: 23px;
		}

		.showcase-section p {
			font-size: 15px;
			line-height: 1.58;
		}
	}
	/* Final card CTA polish */
	.product-card {
		display: grid;
		grid-template-rows: auto 1fr;
	}

	.card-body {
		height: 100%;
		grid-template-rows: auto auto 1fr auto;
		overflow: visible;
	}

	.author-card .card-body {
		grid-template-rows: auto 1fr auto;
	}

	.card-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 7px;
		justify-self: center;
		width: 100%;
		min-height: 38px;
		margin-top: auto;
		padding: 8px 0 6px;
		background: transparent;
		border: 0;
		border-radius: 0;
		color: #1d1b18;
		font-family: "Helvetica Neue", Arial, Helvetica, sans-serif;
		font-size: 13px;
		font-weight: 300;
		line-height: 1.35;
		text-transform: none;
	}

	.card-action span {
		display: inline-block;
		padding-bottom: 1px;
	}

	.card-action svg {
		width: 16px;
		height: 16px;
		flex: 0 0 16px;
		display: block;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.45;
	}
</style>
